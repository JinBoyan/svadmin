{
  "name": "svadmin",
  "private": true,
  "version": "0.5.14",
  "description": "Headless admin framework for Svelte 5 — bring your own backend",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*",
    "example",
    "docs"
  ],
  "scripts": {
    "dev": "cd example && bun run dev",
    "build": "cd example && bun run build",
    "check": "bun run --filter '*' typecheck",
    "lint": "eslint .",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "test": "bun test",
    "test:e2e": "bun run playwright test",
    "docs:dev": "cd docs && bun run dev",
    "docs:build": "cd docs && bun run build",
    "prepare": "husky"
  },
  "keywords": [
    "svelte",
    "svelte5",
    "admin",
    "admin-panel",
    "headless",
    "crud",
    "data-provider",
    "tanstack-query",
    "shadcn-svelte"
  ],
  "license": "MIT",
  "author": "zuohuadong",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zuohuadong/svadmin.git"
  },
  "homepage": "https://github.com/zuohuadong/svadmin#readme",
  "bugs": {
    "url": "https://github.com/zuohuadong/svadmin/issues"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "eslint": "^10.2.0",
    "eslint-plugin-svelte": "^3.17.0",
    "husky": "^9.1.7",
    "svelte-check": "^4.4.6",
    "typescript-eslint": "^8.58.0"
  },
  "dependencies": {
    "typescript": "5.8.2"
  }
}
